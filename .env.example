# PostgreSQL ulanish manzili
# Lokal: postgresql://user:password@localhost:5432/mix_mobile
# Railway/Supabase: ular bergan connection string'ni shu yerga qo'ying
DATABASE_URL="postgresql://user:password@localhost:5432/mix_mobile?schema=public"

# NextAuth uchun maxfiy kalit (production'da: openssl rand -base64 32)
AUTH_SECRET="o-zgartiring-bu-faqat-namuna-kalit"
NEXTAUTH_URL="http://localhost:3000"

# --- Telegram bot (qarz eslatmalari, xavfsizlik, kunlik hisobot) ---
TELEGRAM_BOT_TOKEN="123456:ORNIGA-OZ-BOT-TOKENINGIZNI-QOYING"
TELEGRAM_ADMIN_CHAT_ID="000000000"
TELEGRAM_WEBHOOK_SECRET="openssl-rand--hex-24-bilan-generatsiya-qiling"
CRON_SECRET="openssl-rand--hex-24-bilan-generatsiya-qiling"

# --- Filiallar uchun boshlang'ich login/parol (faqat birinchi seed'da,
#     keyin xodimlar sahifasidan o'zgartirib qo'yish tavsiya etiladi) ---
NAMANGAN_SELLER_LOGIN="namangan_sotuvchi"
NAMANGAN_SELLER_PASSWORD="Namangan-2026-kuchli-parol"
TOSHKENT_SELLER_LOGIN="toshkent_sotuvchi"
TOSHKENT_SELLER_PASSWORD="Toshkent-2026-kuchli-parol"

# --- Google Sheets sinxronizatsiya ---
# Google Apps Script'dagi API_SECRET bilan bir xil bo'lishi shart
SHEETS_SECRET="o-zingiz-tanlagan-maxfiy-kalit"

# --- Telefon rasmlari (Vercel Blob) ---
# Vercel loyihasida "Storage" -> "Blob" yoqilganda BU AVTOMATIK qo'shiladi —
# qo'lda yozish kerak emas. Faqat lokal kompyuterda rasm yuklashni sinab
# ko'rmoqchi bo'lsangiz, Vercel dashboard'dan nusxalab shu yerga qo'ying:
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
