// ============================================================================
// Mix Mobile — Ombor va Sotuv Boshqarish Tizimi
// Prisma Schema
//
// PRD 4.2 bo'limidagi modellar asosida tuzilgan:
// Branch, User, Phone, Sale, Customer, DebtPayment
// + audit log (PRD 4.3: barcha muhim amallar saqlanadi)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------------

enum Role {
  OWNER
  SELLER
}

enum PhoneCondition {
  NEW // Yangi
  USED // Ishlatilgan
  REFURBISHED // Qayta tiklangan
}

enum PhoneStatus {
  IN_STOCK // Omborda
  SOLD // Sotilgan
}

enum Currency {
  UZS // So'm
  USD // AQSH dollari
}

enum PaymentType {
  CASH // Naqd
  CARD // Karta
  CREDIT // Kredit / bo'lib to'lash
}

enum PaymentPlan {
  ONE_TIME // Bir martalik muddat
  MONTHLY // Oylik bo'lib to'lov
}

enum CustomerStatus {
  ACTIVE // Faol qarz
  PAID // To'liq to'langan
  OVERDUE // Muddati o'tgan
  CANCELLED // Sotuv qaytarilgan — qarz bekor
}

enum AuditAction {
  PHONE_CREATED
  PHONE_UPDATED
  PHONE_DELETED
  PHONE_TRANSFERRED
  PHONE_IMPORTED
  SALE_CREATED
  SALE_RETURNED
  DEBT_PAYMENT_CREATED
  BRANCH_CREATED
  BRANCH_DELETED
  BRANCH_ARCHIVED
  USER_CREATED
  USER_UPDATED
  USER_BLOCKED
}

// ----------------------------------------------------------------------------
// MODELS
// ----------------------------------------------------------------------------

model Branch {
  id          String   @id @default(cuid())
  name        String
  address     String
  phoneNumber String
  // Arxivlangan filial ro'yxatlarda ko'rinmaydi (ichida telefon/sotuv
  // tarixi bo'lgan filial O'CHIRILMAYDI — faqat arxivlanadi)
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users     User[]
  phones    Phone[]
  sales     Sale[]
  auditLogs AuditLog[]

  @@map("branches")
}

model User {
  id           String   @id @default(cuid())
  name         String
  login        String   @unique
  passwordHash String
  role         Role
  // Bloklangan xodim (soft-delete): tizimga kira olmaydi, lekin uning
  // sotuvlari/audit tarixi buzilmasligi uchun yozuv O'CHIRILMAYDI
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Faqat SELLER uchun majburiy; OWNER uchun null (barcha filiallarni ko'radi)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  addedPhones Phone[]    @relation("PhoneAddedBy")
  sales       Sale[]     @relation("SaleBySeller")
  auditLogs   AuditLog[]

  @@index([branchId])
  @@index([deletedAt])
  @@map("users")
}

model Phone {
  id          String         @id @default(cuid())
  model       String
  brand       String
  color       String
  storageGB   Int
  imei           String   @unique
  condition      PhoneCondition
  costPrice      Decimal        @db.Decimal(12, 2)
  salePrice      Decimal        @db.Decimal(12, 2)
  // Tan narx va sotuv narxi qaysi valyutada kiritilgan (ikkalasi bitta valyutada)
  currency       Currency       @default(UZS)
  status         PhoneStatus    @default(IN_STOCK)
  photoUrl       String?
  deletedAt      DateTime?
  // Oylik arxiv: o'tgan oylarda sotilgan telefonlar har oy boshida
  // arxivga o'tadi (api/cron/archive-sold) — ombor ro'yxatida ko'rinmaydi,
  // lekin hisobotlar/tarix uchun bazada to'liq saqlanadi. O'CHIRILMAYDI.
  archivedAt     DateTime?
  // Qo'shimcha maydonlar
  ramGB          Int?
  batteryHealth  Int?           // 0-100 foiz, faqat ishlatilgan/refurbished uchun
  hasBox         Boolean        @default(false)
  hasCharger     Boolean        @default(false)
  hasDocuments   Boolean        @default(false)
  warrantyMonths Int            @default(0) // 0=kafolatsiz, 1,3,6,12,24 oy
  supplier       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  addedById String
  addedBy   User   @relation("PhoneAddedBy", fields: [addedById], references: [id])

  sale Sale?

  @@index([branchId])
  @@index([status])
  @@index([model, brand])
  @@index([imei])
  @@index([deletedAt])
  @@index([archivedAt])
  @@map("phones")
}

model Sale {
  id          String      @id @default(cuid())
  finalPrice  Decimal     @db.Decimal(12, 2)
  // finalPrice qaysi valyutada kiritilgan
  currency    Currency    @default(UZS)
  paymentType PaymentType
  saleDate    DateTime    @default(now())
  // Telegram kanaliga "sotildi" posti chiqarilganmi (har 5 sotuvda
  // bitta post — lib/telegram-channel.ts)
  postedToChannel Boolean @default(false)
  // Qaytarilgan sotuv: telefon omborga qaytadi, sotuv hisobotlardan
  // chiqadi, lekin yozuv tarix uchun saqlanadi (O'CHIRILMAYDI)
  returnedAt   DateTime?
  returnReason String?

  phoneId String @unique
  phone   Phone  @relation(fields: [phoneId], references: [id])

  sellerId String
  seller   User   @relation("SaleBySeller", fields: [sellerId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  // Faqat CREDIT to'lov turida yaratiladi (PRD 3.6)
  customer Customer?

  @@index([branchId])
  @@index([sellerId])
  @@index([saleDate])
  @@index([returnedAt])
  @@map("sales")
}

model Customer {
  id          String         @id @default(cuid())
  fullName    String
  phoneNumber String
  totalAmount Decimal        @db.Decimal(12, 2)
  paidAmount  Decimal        @default(0) @db.Decimal(12, 2)
  // Qarz valyutasi — sotuv valyutasidan ko'chiriladi (totalAmount, paidAmount
  // va barcha DebtPayment'lar shu valyutada)
  currency    Currency       @default(UZS)
  dueDate     DateTime
  paymentPlan PaymentPlan
  status      CustomerStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  saleId String @unique
  sale   Sale   @relation(fields: [saleId], references: [id])

  payments DebtPayment[]

  @@index([status])
  @@index([dueDate])
  @@index([phoneNumber])
  @@map("customers")
}

model DebtPayment {
  id          String      @id @default(cuid())
  amount      Decimal     @db.Decimal(12, 2)
  paymentType PaymentType @default(CASH)
  paymentDate DateTime    @default(now())
  note        String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("debt_payments")
}

// USD/UZS kursi — kuniga bir marta CBU (Markaziy bank) API'sidan olinib,
// shu jadvalga saqlanadi. Har so'rovda API chaqirilmaydi (lib/exchange-rate.ts).
model ExchangeRate {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  usdToUzs  Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  @@map("exchange_rates")
}

// PRD 4.3: "Barcha muhim amallar (sotuv, telefon o'chirish, qarz to'lovi)
// tizim jurnalida (audit log) saqlanadi — kim, qachon, nima qilgani"
model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  details   Json? // amal haqida qo'shimcha ma'lumot (masalan, o'chirilgan telefon IMEI'si)
  createdAt DateTime    @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  @@index([userId])
  @@index([branchId])
  @@index([createdAt])
  @@map("audit_logs")
}
